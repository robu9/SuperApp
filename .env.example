# SuperApp — copy to `.env` and fill in values

# Gemini (chat + optional STT)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Official Supermemory local server (https://supermemory.ai/docs/self-hosting/overview)
# 1. Install: npm run memory:install  (macOS/Linux) or scripts/supermemory-wsl.ps1 (Windows)
# 2. Start:   npm run memory:start
# 3. Copy the sm_... API key printed on first boot into SUPERMEMORY_API_KEY below
SUPERMEMORY_BASE_URL=http://127.0.0.1:6767
SUPERMEMORY_API_KEY=
SUPERMEMORY_CONTAINER_TAG=superapp
